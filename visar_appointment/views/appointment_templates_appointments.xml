<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="visar_appointment_info_price" inherit_id="website_appointment_sale.appointment_info">
        <xpath expr="//span[hasclass('o_appointment_details_price')]" position="replace">
            <t t-set="quote" t-value="visar_quote or False"/>
            <t t-set="quote_currency" t-value="quote and request.env['res.currency'].browse(quote['currency_id']) or False"/>
            <span t-if="quote" class="o_appointment_details_price o_visar_quote_price flex-grow-1">
                <t t-foreach="quote['lines']" t-as="line">
                    <div class="d-flex justify-content-between gap-2 small mb-1"
                         t-att-class="'text-muted' if line.get('is_free') else ('ps-2' if line.get('is_addon') else None)">
                        <span t-esc="line['name']"/>
                        <span>
                            <span t-if="line.get('has_discounted_price') and line.get('list_price')"
                                  class="oe_striked_price me-1"
                                  t-out="line['list_price']"
                                  t-options="{'widget': 'monetary', 'display_currency': quote_currency}"/>
                            <span t-out="line['price']"
                                  t-options="{'widget': 'monetary', 'display_currency': quote_currency}"/>
                        </span>
                    </div>
                </t>
                <div class="d-flex justify-content-between pt-1 border-top">
                    <strong>Total</strong>
                    <strong t-out="quote['total']"
                            t-options="{'widget': 'monetary', 'display_currency': quote_currency}"/>
                </div>
            </span>
            <t t-else="">
                <t t-set="combination_info" t-value="appointment_type.product_id.product_tmpl_id._get_combination_info(
                    product_id=appointment_type.product_id.id,
                    add_qty=asked_capacity if isDetailsManageCapacity else 1.0)"/>
                <span class="o_appointment_details_price">
                    <strong t-out="combination_info['price'] * asked_capacity if isDetailsManageCapacity else combination_info['price']"
                        t-options="{'widget': 'monetary', 'display_currency': combination_info['currency']}"/>
                    <span t-if="not isDetails and combination_info['has_discounted_price']" class="oe_striked_price"
                        t-out="combination_info['list_price']"
                        t-options="{'widget': 'monetary', 'display_currency': combination_info['currency']}"/>
                </span>
            </t>
        </xpath>
    </template>

</odoo>
