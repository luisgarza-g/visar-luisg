<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_visar" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.visar</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Visar" name="visar_base">
                    <block title="Configuración Visar">
                        <setting string="Producto valoración técnica"
                                 help="Producto cobrado en el flujo de valoración (solo zona).">
                            <field name="visar_valuation_product_tmpl_id"/>
                        </setting>
                        <setting string="Factor combo (respaldo)"
                                 help="Usado solo si no hay reglas de combo activas.">
                            <field name="visar_combo_corte_factor"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
