<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="appointment_resource_view_form_visar" model="ir.ui.view">
        <field name="name">appointment.resource.view.form.visar</field>
        <field name="model">appointment.resource</field>
        <field name="inherit_id" ref="appointment.appointment_resource_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Visar Citas" name="visar">
                    <group>
                        <field name="visar_zone_ids" widget="many2many_tags"/>
                        <field name="visar_service_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
