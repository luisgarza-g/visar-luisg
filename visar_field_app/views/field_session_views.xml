<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="visar_field_session_view_list" model="ir.ui.view">
        <field name="name">visar.field.session.list</field>
        <field name="model">visar.field.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'open'"
                       decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="visar_field_session_view_form" model="ir.ui.view">
        <field name="name">visar.field.session.form</field>
        <field name="model">visar.field.session</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_close" type="object" string="Cerrar sesión"
                            class="btn-primary" invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="visar_field_session_action" model="ir.actions.act_window">
        <field name="name">Sesiones de técnicos</field>
        <field name="res_model">visar.field.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="visar_field_open_app_action" model="ir.actions.act_url">
        <field name="name">Abrir App de Campo</field>
        <field name="url">/visar/field</field>
        <field name="target">new</field>
    </record>

</odoo>
