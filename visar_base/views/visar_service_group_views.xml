<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="visar_service_group_view_list" model="ir.ui.view">
        <field name="name">visar.service.group.list</field>
        <field name="model">visar.service.group</field>
        <field name="arch" type="xml">
            <list string="Grupos de servicio">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="show_in_wizard"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="visar_service_group_view_form" model="ir.ui.view">
        <field name="name">visar.service.group.form</field>
        <field name="model">visar.service.group</field>
        <field name="arch" type="xml">
            <form string="Grupo de servicio">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="show_in_wizard"/>
                        <field name="wizard_label"/>
                        <field name="wizard_help"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Dimensiones / sub-servicios">
                            <field name="dimension_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="wizard_label"/>
                                    <field name="product_tmpl_id"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="visar_service_group_action" model="ir.actions.act_window">
        <field name="name">Grupos de servicio</field>
        <field name="res_model">visar.service.group</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
