<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="visar_service_tier_view_list" model="ir.ui.view">
        <field name="name">visar.service.tier.list</field>
        <field name="model">visar.service.tier</field>
        <field name="arch" type="xml">
            <list string="Tabulador de servicios" editable="bottom">
                <field name="product_tmpl_id"/>
                <field name="name"/>
                <field name="m2_min"/>
                <field name="m2_max"/>
                <field name="product_id"
                       domain="[('product_tmpl_id', '=', product_tmpl_id)]"/>
                <field name="is_valuation"/>
                <field name="is_free"/>
                <field name="combo_discount_eligible"/>
            </list>
        </field>
    </record>

    <record id="visar_service_tier_view_form" model="ir.ui.view">
        <field name="name">visar.service.tier.form</field>
        <field name="model">visar.service.tier</field>
        <field name="arch" type="xml">
            <form string="Tramo de servicio">
                <sheet>
                    <group>
                        <field name="product_tmpl_id"/>
                        <field name="name"/>
                        <field name="m2_min"/>
                        <field name="m2_max"/>
                        <field name="product_id"
                               domain="[('product_tmpl_id', '=', product_tmpl_id)]"/>
                        <field name="is_valuation"/>
                        <field name="is_free"/>
                        <field name="combo_discount_eligible"/>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="visar_service_tier_action" model="ir.actions.act_window">
        <field name="name">Tabulador de servicios</field>
        <field name="res_model">visar.service.tier</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
