<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_visar_appointment" model="ir.ui.view">
        <field name="name">product.template.form.visar.appointment</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="visar_base.product_template_form_view_visar"/>
        <field name="arch" type="xml">
            <field name="visar_dimension_id" position="after">
                <field name="visar_appointment_type_id"
                       invisible="not visar_is_service"
                       required="visar_is_service"/>
            </field>
        </field>
    </record>

    <record id="product_template_form_view_visar_upsell_order" model="ir.ui.view">
        <field name="name">product.template.form.visar.upsell.order</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="website_sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='alternative_product_ids']" position="after">
                <xpath expr="//field[@name='optional_product_ids']" position="move"/>
            </xpath>
            <xpath expr="//field[@name='optional_product_ids']" position="after">
                <xpath expr="//field[@name='visar_optional_line_ids']" position="move"/>
            </xpath>
        </field>
    </record>

</odoo>
