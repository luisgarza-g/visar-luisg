<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="visar_zone_view_list" model="ir.ui.view">
        <field name="name">visar.zone.list</field>
        <field name="model">visar.zone</field>
        <field name="arch" type="xml">
            <list string="Zonas" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="pricelist_id"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="visar_zone_view_form" model="ir.ui.view">
        <field name="name">visar.zone.form</field>
        <field name="model">visar.zone</field>
        <field name="arch" type="xml">
            <form string="Zona">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="pricelist_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="visar_zone_action" model="ir.actions.act_window">
        <field name="name">Zonas</field>
        <field name="res_model">visar.zone</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
